<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.settings.SettingsFragment">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_face" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_body" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_cam" />
    </com.google.android.material.tabs.TabLayout>

    <FrameLayout
        android:id="@+id/settings_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabLayout">

        <!-- Face Settings -->
        <ScrollView
            android:id="@+id/layout_face_settings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Face Stylizer Model:"
                    android:textSize="18sp" />

                <RadioGroup
                    android:id="@+id/radioGroup_model"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <RadioButton
                        android:id="@+id/radio_animegan_hayao"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AnimeGAN v2 (Hayao)" />

                    <RadioButton
                        android:id="@+id/radio_animegan_paprika"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AnimeGAN v2 (Paprika)" />

                    <RadioButton
                        android:id="@+id/radio_mediapipe_default"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MediaPipe Default" />

                    <RadioButton
                        android:id="@+id/radio_cartoongan_default"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CartoonGAN Default" />

                    <RadioButton
                        android:id="@+id/radio_semi_filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SEMI-Filter (Non-AI)" />
                </RadioGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Landmark Options:"
                    android:textSize="18sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_use_face_landmark"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Use Face Landmarker"
                    android:checked="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Face Landmarker Delegate:"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/radioGroup_face_delegate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radio_face_cpu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CPU"
                        android:layout_marginEnd="16dp" />

                    <RadioButton
                        android:id="@+id/radio_face_gpu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPU" />
                </RadioGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Pose Landmarker Delegate:"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/radioGroup_pose_delegate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radio_pose_cpu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CPU"
                        android:layout_marginEnd="16dp" />

                    <RadioButton
                        android:id="@+id/radio_pose_gpu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPU" />
                </RadioGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Select Rendering Mode:"
                    android:textSize="18sp" />

                <RadioGroup
                    android:id="@+id/radioGroup_render_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <RadioButton
                        android:id="@+id/radio_face_only"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Face Only (Background Original)" />

                    <RadioButton
                        android:id="@+id/radio_full_frame"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full Frame (Everything Stylized)" />
                </RadioGroup>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_face_mirror_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Mirror Mode (Swap Left/Right)"
                    android:textSize="18sp" />
            </LinearLayout>
        </ScrollView>

        <!-- Body Settings -->
        <ScrollView
            android:id="@+id/layout_body_settings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_body_model"
                    android:textSize="18sp" />

                <RadioGroup
                    android:id="@+id/radioGroup_body_model"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <RadioButton
                        android:id="@+id/radio_body_mediapipe_pose"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PoseLandmark\n(Framework: MediaPipe, Backbone: BlazePose, Model: Lite, Res: 256x256)" />

                    <RadioButton
                        android:id="@+id/radio_body_mlkit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ML Kit\n(Framework: ML Kit, Backbone: Selfie Segmenter, Model: Base, Res: 256x256)" />

                    <RadioButton
                        android:id="@+id/radio_body_yolact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YOLACT\n(Framework: TFLite, Backbone: ResNet-50, Model: Float16, Res: 550x550)" />

                    <RadioButton
                        android:id="@+id/radio_body_yolo26n_seg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="yolo26n-seg\n(Framework: TFLite, Model: Float16, Res: 640x640)" />

                    <RadioButton
                        android:id="@+id/radio_body_yolox"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YOLOX + RVM\n(Detection + Segmentation)" />

                    <RadioButton
                        android:id="@+id/radio_body_yolox_tiny"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YOLOX tiny\n(Detection Bounding Box Only)" />

                    <RadioButton
                        android:id="@+id/radio_body_modnet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MODNet\n(Framework: TFLite, Backbone: MODNet, Model: Float16, Res: 256x256)" />

                    <RadioButton
                        android:id="@+id/radio_body_rvm_320"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RVM 192x320\n(Framework: TFLite, Backbone: ResNet-50, Model: Float16)" />

                    <RadioButton
                        android:id="@+id/radio_body_rvm_1280"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RVM 720x1280\n(Framework: TFLite, Backbone: ResNet-50, Model: Float16)" />
                </RadioGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/settings_body_delegate"
                    android:textSize="18sp" />

                <RadioGroup
                    android:id="@+id/radioGroup_body_delegate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <RadioButton
                        android:id="@+id/radio_body_cpu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CPU"
                        android:layout_marginEnd="16dp" />

                    <RadioButton
                        android:id="@+id/radio_body_gpu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPU" />

                    <RadioButton
                        android:id="@+id/radio_body_nnapi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NNAPI (NPU)" />
                </RadioGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Webcam Stream Quality"
                    android:textSize="18sp" />

                <RadioGroup
                    android:id="@+id/radioGroup_rtsp_quality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <RadioButton
                        android:id="@+id/radio_quality_high"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="High Quality (stream1)"
                        android:layout_marginEnd="16dp" />

                    <RadioButton
                        android:id="@+id/radio_quality_low"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Low Quality (stream2)" />
                </RadioGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/settings_body_gradient_start_color"
                    android:textSize="18sp" />

                <EditText
                    android:id="@+id/edit_body_start_color"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="#FF0000"
                    android:inputType="text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/settings_body_gradient_end_color"
                    android:textSize="18sp" />

                <EditText
                    android:id="@+id/edit_body_end_color"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="#0000FF"
                    android:inputType="text" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_body_mirror_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Mirror Mode (Swap Left/Right)"
                    android:textSize="18sp" />

            </LinearLayout>
        </ScrollView>

        <!-- CAM Settings -->
        <ScrollView
            android:id="@+id/layout_cam_settings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_cam_source"
                    android:textSize="18sp" />

                <RadioGroup
                    android:id="@+id/radioGroup_cam_source"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <RadioButton
                        android:id="@+id/radio_cam_embedded"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_cam_embedded" />

                    <RadioButton
                        android:id="@+id/radio_cam_rtsp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_cam_rtsp" />
                </RadioGroup>

                <LinearLayout
                    android:id="@+id/layout_rtsp_fields"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RTSP IP" />

                    <EditText
                        android:id="@+id/edit_rtsp_ip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="192.168.0.21"
                        android:inputType="text" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="RTSP ID" />

                    <EditText
                        android:id="@+id/edit_rtsp_id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="admin"
                        android:inputType="text" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="RTSP PW" />

                    <EditText
                        android:id="@+id/edit_rtsp_pw"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="password"
                        android:inputType="textPassword" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>